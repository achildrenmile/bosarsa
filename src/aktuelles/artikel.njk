---
layout: base.njk
pageCSSFile: "/css/aktuelles.css"
activeNav: aktuelles
pagination:
  data: aktuelles
  size: 1
  alias: article
permalink: /aktuelles/{{ article.slug }}/
eleventyComputed:
  title: "{{ article.title }} — BOS-ARSA"
  description: "{{ article.intro }}"
  canonical: "https://bosarsa.oeradio.at/aktuelles/{{ article.slug }}/"
---

<div class="page-content page-content--wide">
  <a href="/aktuelles/" class="aktuelles-back">← Zurück zu Aktuelles</a>

  {% if article.image %}
  <div class="aktuelles-article__hero">
    <img src="{{ article.image }}" alt="{{ article.imageAlt }}">
  </div>
  {% endif %}

  <div class="aktuelles-article__meta">
    <span class="aktuelles-article__date">{{ article.dateDisplay }}</span>
    <span class="aktuelles-tag aktuelles-tag--{{ article.tag }}">{{ article.tagLabel }}</span>
  </div>

  <h1 class="aktuelles-article__title">{{ article.title }}</h1>
  <p class="aktuelles-article__intro">{{ article.intro }}</p>

  {% for section in article.sections %}
  <h2 class="aktuelles-article__heading">{{ section.heading }}</h2>

  {% if section.type == "table" %}
  <div class="aktuelles-article__table-wrap">
    <table class="aktuelles-article__table">
      <thead>
        <tr>
          {% for col in section.columns %}
          <th>{{ col }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in section.rows %}
        <tr>
          {% for cell in row %}
          <td>{{ cell }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% elif section.type == "text" %}
  <p class="aktuelles-article__text">{{ section.content }}</p>

  {% elif section.type == "image" %}
  <figure class="aktuelles-article__figure">
    <img src="{{ section.src }}" alt="{{ section.alt }}" loading="lazy">
    {% if section.caption %}
    <figcaption>{{ section.caption }}</figcaption>
    {% endif %}
  </figure>

  {% elif section.type == "list" %}
  <ul class="aktuelles-article__list">
    {% for item in section.items %}
    <li>{{ item }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  {% endfor %}

  {% if article.author %}
  <p class="aktuelles-article__author">73 de {{ article.author }}</p>
  {% endif %}
</div>
